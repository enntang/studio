# 複製這個檔案為 .env，填入你的 Notion integration 資訊（.env 不會進版控）
# NOTION_API_KEY：Notion integration 的 Internal Integration Secret
# NOTION_DATABASE_ID：Works 資料庫的 ID（資料庫網址中 notion.so/ 後面那串 32 字元）
# NOTION_WALLPAPERS_DATABASE_ID：Wallpapers 資料庫的 ID（選填，沒填就略過桌布同步）
NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_WALLPAPERS_DATABASE_ID=
